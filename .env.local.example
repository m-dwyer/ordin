# Dev secrets for the eval loop — copy to `.env.local` (gitignored) and
# fill in. mise sources this file automatically via `.mise.toml`.
#
# One-time setup on a fresh clone:
#   cp .env.local.example .env.local
#   # then edit .env.local with a key of your choice, e.g.:
#   # LITELLM_MASTER_KEY=sk-$(openssl rand -hex 16)

# Master key for the LiteLLM proxy. Required for `pnpm eval`. Used as
# both the proxy's server-side auth (passed in via docker-compose) and
# the harness's client-side auth (read by AiSdkRuntime).
LITELLM_MASTER_KEY=sk-ordin-local-dev

# Default model the eval suite composes phases with. Required (the
# eval suite refuses to run without an explicit model — no silent
# fallback to a hardcoded default). Override per-run by prefixing the
# command: `ORDIN_EVAL_MODEL=qwen3-coder-30b pnpm eval`.
#
# Must be a LiteLLM alias from litellm/config.yaml's model_list, or
# any Ollama tag passed through via the `*` wildcard route there.
# Common choices: qwen3-8b, qwen3-14b, qwen3-coder-30b, qwen3-32b.
# Avoid models < 7B for tool-use unless you've verified they emit
# `tool_calls` structurally.
ORDIN_EVAL_MODEL=qwen3-14b

# Optional: separate judge model. Defaults to ORDIN_EVAL_MODEL above
# — the same model judges its own output, fine for most runs. Set
# explicitly when you want a stronger model scoring weaker model
# output (e.g. judging qwen3-8b output with qwen3-coder-30b).
# ORDIN_EVAL_JUDGE_MODEL=qwen3-coder-30b

# Optional: backend API keys. Only needed for the corresponding
# providers in litellm/config.yaml. Leave blank if running local-only.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
