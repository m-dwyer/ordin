#!/usr/bin/env sh
# Resolve this script through symlinks so `bun link`, Homebrew,
# and any other installer that symlinks bin/ordin onto PATH still
# locates the real ordin repo (where node_modules and src/ live).
resolved="$0"
while [ -L "$resolved" ]; do
  target="$(readlink "$resolved")"
  case "$target" in
    /*) resolved="$target" ;;
    *) resolved="$(dirname "$resolved")/$target" ;;
  esac
done
ORDIN_ROOT="$(cd "$(dirname "$resolved")/.." && pwd)"

exec bun "$ORDIN_ROOT/src/cli/index.ts" "$@"
